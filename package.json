{
    "name": "match-pc",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "next dev --webpack",
        "dev:turbo": "next dev",
        "build": "next build",
        "build:railway": "cross-env CI=1 next build",
        "build:windows": "next build --webpack",
        "start": "next start",
        "start:railway": "node .next/standalone/server.js",
        "lint": "biome check",
        "lint:ts": "tsc --noEmit",
        "format": "biome format --write",
        "test": "",
        "test:logic": "node --import tsx --test src/modules/match/_logic/*.test.ts",
        "theme:check": "tsx scripts/check-theme-index.ts",
        "icon:build": "svgr src/assets/icons",
        "icon2:build": "pnpm dlx svg-to-component-cli@^1 parse -o src/components/icons2 src/assets/icons2",
        "icon2:preview": "pnpm dlx svg-to-component-cli@^1 preview src/assets/icons2",
        "sync:agents": "tsx scripts/sync-agent-configs.ts"
    },
