# App display name (used in metadata, OG tags, page titles)
NEXT_PUBLIC_APP_NAME=GOTOBET

# 应用运行环境
NEXT_PUBLIC_APP_ENV=

# Site base URL (used for metadataBase, OG absolute URLs, sitemap)
NEXT_PUBLIC_SITE_URL=

# API URLs (refer to .env.development, .env.production)
# 本地开发 API 根域回退（仅 localhost 需要）
NEXT_PUBLIC_SERVICE_ROOT_DOMAIN=
# websocket 子域前缀，例如 xp-ws-test1-api/ws
NEXT_PUBLIC_WEBSOCKET_SERVICE=
# websocket日志打印
NEXT_PUBLIC_SHOW_WS_LOG=

# 服务子域前缀，例如 xp-service-test1-api；带路径可写 sport-api/api
NEXT_PUBLIC_UOF_SERVICE=
NEXT_PUBLIC_USER_SERVICE=
NEXT_PUBLIC_PAYMENT_SERVICE=
NEXT_PUBLIC_GAME_SERVICE=
NEXT_PUBLIC_SSE_SERVICE=
NEXT_PUBLIC_SPORT_SERVICE=
NEXT_PUBLIC_ANALYTICS_SERVICE=
NEXT_PUBLIC_ACTIVITY_SERVICE=

# ========== Firebase (values in .env.production.local or CI/CD) ==========
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ========== Google Analytics (values in .env.production.local or CI/CD) ==========
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ========== Sentry (values in .env.production.local or CI/CD) ==========
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_ENABLE=

NEXT_PUBLIC_DEV_REACT_GRAB_ENABLE=
NEXT_PUBLIC_DEV_SPACINGJS_ENABLE=

# ========== 世界杯活动ID ==========
NEXT_PUBLIC_ACTIVITY_WORLD_CUP_PASS_ID_BR=
NEXT_PUBLIC_ACTIVITY_WORLD_CUP_PASS_ID_MX=
# VIP活动ID-巴西 
NEXT_PUBLIC_ACTIVITY_VIP_ID_BR=
# VIP活动ID-墨西哥 
NEXT_PUBLIC_ACTIVITY_VIP_ID_MX=

# 关闭检查kyc
NEXT_PUBLIC_DISABLE_KYC_VERIFY=

# 20260521上线特性展示
NEXT_PUBLIC_SHOW_FEATURE_20260521=

# 详情页投注项测试定位属性开关，仅 test1 环境开启。
NEXT_PUBLIC_ENABLE_MATCH_OUTCOME_TEST_DATA=

# 是否显示VIP侧边栏菜单入口
NEXT_PUBLIC_SHOW_VIP_MENU=

# 是否显示世界杯联赛冠军盘卡片
NEXT_PUBLIC_SHOW_WORLD_CUP_CHAMPION_CARD=

# ========== LiveChat ==========
# LiveChat license number；非密钥，可公开提交。
NEXT_PUBLIC_LIVECHAT_LICENSE=
# 总开关：true 才会真正初始化 LiveChat。
NEXT_PUBLIC_LIVECHAT_ENABLED=
