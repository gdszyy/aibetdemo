# 关闭检查kyc
NEXT_PUBLIC_DISABLE_KYC_VERIFY=true

NEXT_PUBLIC_SHOW_FEATURE_20260521=true

# 本地开发 sentry 上报开关
NEXT_PUBLIC_ENABLE_SENTRY_IN_DEV=false

# 详情页投注项测试定位属性开关，仅 dev和test1 环境开启。
NEXT_PUBLIC_ENABLE_MATCH_OUTCOME_TEST_DATA=true

# 本地开发 sentry 上报开关
NEXT_PUBLIC_SENTRY_ENABLE=false

# 详情页投注项测试定位属性开关，仅 dev和test1 环境开启。
NEXT_PUBLIC_ENABLE_MATCH_OUTCOME_TEST_DATA=true

# 是否显示VIP侧边栏菜单入口
